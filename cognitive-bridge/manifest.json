{
  "manifest_version": 3,
  "name": "Cognitive Bridge",
  "version": "0.1.0",
  "description": "Reduce cognitive load during AI assistant responses",
  "permissions": [
    "storage",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Cognitive Bridge"
  },
  "icons": {
    "16": "dist/icons/icon-16.png",
    "48": "dist/icons/icon-48.png",
    "128": "dist/icons/icon-128.png"
  }
}
