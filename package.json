{
  "name": "clawpay",
  "version": "0.1.0",
  "description": "Open-source Stripe MCP Server for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clawpay": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "DISCLAIMER.md",
    "Formula"
  ],
  "scripts": {
