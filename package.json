  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "@types/qrcode-terminal": "^0.12.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
